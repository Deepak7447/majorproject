<% layout("/layouts/boilerplate") -%>

<div class="row">
    <div class="col-md-8 offset-md-2">

        <h3 class="mb-3"><%= listing.title %></h3>

        <div class="card show-card mb-4">
            <img src="<%= listing.image.url || listing.image %>" class="card-img-top show-img" alt="Listing Image">
            <div class="card-body">

                <p class="card-text">
                    <strong>Owned by:</strong>
                    <i><%= listing.owner.username %></i>
                </p>

                <p class="card-text">
                    <%= listing.description %>
                </p>

                <p class="card-text">
                    <strong>Price:</strong>
                    ₹ <%= listing.price.toLocaleString("en-IN") %>
                </p>

                <p class="card-text">
                    <strong>Location:</strong>
                    <%= listing.location %>
                </p>

                <p class="card-text">
                    <strong>Country:</strong>
                    <%= listing.country %>
                </p>

            </div>
        </div>

        <!-- Edit/Delete buttons only for owner -->
        <% if (currentUser && listing.owner._id.equals(currentUser._id)) { %>

            <div class="d-flex gap-2 mb-4">

                <a
                    href="/listings/<%= listing._id %>/edit"
                    class="btn btn-dark"
                >
                    Edit
                </a>

                <form
                    method="POST"
                    action="/listings/<%= listing._id %>?_method=DELETE"
                >
                    <button
                        type="submit"
                        class="btn btn-danger"
                    >
                        Delete
                    </button>
                </form>

            </div>

        <% } %>

        <hr>

        <!-- Review Form -->
        <% if (currentUser) { %>

            <h4 class="mb-3">Leave a Review</h4>

            <form
                action="/listings/<%= listing._id %>/reviews"
                method="POST"
                class="needs-validation mb-4"
                novalidate
            >

                <div class="mb-3">
                    <label for="rating" class="form-label">
                        Rating
                    </label>

                    <input
                        type="range"
                        min="1"
                        max="5"
                        id="rating"
                        name="review[rating]"
                        class="form-range"
                    >
                </div>

                <div class="mb-3">
                    <label for="comment" class="form-label">
                        Comment
                    </label>

                    <textarea
                        name="review[comment]"
                        id="comment"
                        rows="4"
                        class="form-control"
                        placeholder="Write your review..."
                        required
                    ></textarea>

                    <div class="invalid-feedback">
                        Please enter a comment.
                    </div>
                </div>

                <button
                    type="submit"
                    class="btn btn-outline-dark"
                >
                    Submit Review
                </button>

            </form>

            <hr>

        <% } %>

        <!-- Average Rating -->
        <h4>All Reviews</h4>

        <p>
            <strong>Average Rating:</strong>

            <% if (listing.reviews.length > 0) { %>

                <%= (
                    listing.reviews.reduce(
                        (sum, review) => sum + review.rating,
                        0
                    ) / listing.reviews.length
                ).toFixed(1) %> Stars

            <% } else { %>

                No reviews yet

            <% } %>
        </p>

        <!-- Reviews -->
        <div class="row">

            <% for (let review of listing.reviews) { %>

                <div class="col-md-5 mb-3">

                    <div class="card show-card h-100">

                        <div class="card-body">

                            <h5 class="card-title">
                                <%= review.author.username %>
                            </h5>

                            <p class="card-text">
                                <%= review.comment %>
                            </p>

                            <p class="card-text">
                                <%= review.rating %> Stars
                            </p>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <% if (currentUser && review.author._id.equals(currentUser._id)) { %>
                            <form
                                method="POST"
                                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                            >
                                <button
                                    type="submit"
                                    class="btn btn-sm btn-dark"
                                >
                                    Delete
                                </button>
                            </form>
                            <% } %>

                        </div>

                    </div>

                </div>

            <% } %>

        </div>

    </div>
</div>