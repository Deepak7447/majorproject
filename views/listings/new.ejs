
<% layout("/layouts/boilerplate") %>
    <div class="row">

   <div class="col-md-8 offset-md-3">
    <br><br>
    <h3>Create New Listing</h3>
    <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
       
        <div class="mb-3">
        <label for="title" class="form-label">Enter Title</label>
        <input type="text" class="form-control" name="listing[title]" placeholder="Enter your Title" required>
        <div class="invalid-feedback">
          Please enter a title.
        </div>
        </div>
        

        <div class="mb-3">
        <label for="description" class="form-label">Enter Description</label>
        <textarea class="form-control" name="listing[description]" required></textarea>
        <div class="invalid-feedback">
          Please enter a description.
        </div>
        </div>

        
        <div class="mb-3">
        <label for="image" class="form-label">Upload Image</label>
        <input type="file" class="form-control" name="listing[image]" placeholder="Enter Image URL">
        <div class="invalid-feedback">
          Please upload an image.
        </div>
        </div>


        <div class=row>
        <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Enter Price</label>
        <input type="number" class="form-control" name="listing[price]" placeholder="Enter Price" required>
        <div class="invalid-feedback">
          Please enter a price. 
        </div>

        <div class="mb-3 col-md-8">
        <label for="country" class="form-label">Country</label>
        <input type="text" class="form-control" name="listing[country]" placeholder="Enter Country" required>
        <div class="invalid-feedback">
          Please enter a country.
        </div>
         </div>

        <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input type="text" class="form-control" name="listing[location]" placeholder="Enter Location" required>
        <div class="invalid-feedback">
          Please enter a location.
        </div>
       
       
        <br><br>
        <button type="submit">Create Listing</button>
        <br><br>

        <button class="btn btn-dark" type="submit">Save</button>
        <br><br>
    </form>
     </div>
     </div>
